{
  "name": "vertex-anthropic",
  "displayName": "Vertex Anthropic Provider",
  "description": "VS Code Chat Model Provider for Vertex AI Anthropic",
  "publisher": "jorsm",
  "version": "0.1.2",
  "icon": "images/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jorsm/vertex-anthropic"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vertexAnthropic.refreshModels",
        "title": "Vertex Anthropic: Refresh Models"
      },
      {
        "command": "vertexAnthropic.generateCommitMessage",
        "title": "Vertex Anthropic: Generate Commit Message",
        "shortTitle": "Generate Commit Message",
        "icon": "$(wand)"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "vertexAnthropic.generateCommitMessage",
          "when": "scmProvider == 'git'",
          "group": "navigation"
        }
      ]
    },
    "languageModelChatProviders": [
      {
        "identifier": "vertex-anthropic",
        "name": "Vertex Claude (Anthropic)",
        "displayName": "Vertex Claude (Anthropic)",
        "vendor": "Google Cloud Vertex AI"
      }
    ],
    "configuration": {
      "title": "Vertex Anthropic",
      "properties": {
        "vertexAnthropic.projectId": {
          "type": "string",
          "default": "",
          "description": "GCP Project ID to use with Vertex AI. Models and regions are auto-discovered."
        },
        "vertexAnthropic.hideBillingWarning": {
          "type": "boolean",
          "default": false,
          "description": "Hide the Estimated Costs warning banner on the Usage Dashboard."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.34.0",
    "typescript": "^5.9.2"
  },
  "extensionDependencies": [
    "vscode.git"
  ],
  "dependencies": {
    "@anthropic-ai/vertex-sdk": "^0.14.4",
    "@google/genai": "^1.46.0",
    "@modelcontextprotocol/sdk": "^1.27.1"
  }
}
