{
  "name": "vertex-anthropic",
  "displayName": "Vertex AI Models Chat Provider",
  "description": "VS Code Chat Model Provider for Google Cloud Vertex AI (Gemini & Claude)",
  "publisher": "jorsm",
  "version": "0.2.5",
  "icon": "images/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jorsm/vertex-anthropic"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vertexAiChat.dumpTools",
        "title": "Vertex AI Models Chat Provider: Dump Installed Tools Schema"
      },
      {
        "command": "vertexAiChat.refreshModels",
        "title": "Vertex AI Models Chat Provider: Refresh Models"
      },
      {
        "command": "vertexAiChat.generateCommitMessage",
        "title": "Vertex AI Models Chat Provider: Generate Commit Message",
        "shortTitle": "Generate Commit Message",
        "icon": "$(wand)"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "vertexAiChat.generateCommitMessage",
          "when": "scmProvider == 'git'",
          "group": "navigation"
        }
      ]
    },
    "languageModelChatProviders": [
      {
        "identifier": "vertex-anthropic",
        "name": "Vertex AI Models Chat Provider",
        "displayName": "Vertex AI Models Chat Provider",
        "vendor": "Google Cloud Vertex AI"
      }
    ],
    "configuration": {
      "title": "Vertex AI Models Chat Provider",
      "properties": {
        "vertexAiChat.projectId": {
          "type": "string",
          "default": "",
          "description": "GCP Project ID to use with Vertex AI. Models and regions are auto-discovered."
        },
        "vertexAiChat.hideBillingWarning": {
          "type": "boolean",
          "default": false,
          "description": "Hide the Estimated Costs warning banner on the Usage Dashboard."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "clean": "rm -rf out",
    "bundle": "npm run clean && esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "bundle-dev": "npm run clean && esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch-bundle": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "eslint": "^9.34.0",
    "typescript": "^5.9.2"
  },
  "extensionDependencies": [
    "vscode.git"
  ],
  "dependencies": {
    "@anthropic-ai/vertex-sdk": "^0.14.4",
    "@google/genai": "^1.46.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  }
}
