{
  "name": "vertex-anthropic",
  "displayName": "Vertex Anthropic Provider",
  "description": "VS Code Chat Model Provider for Vertex AI Anthropic",
  "version": "0.0.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/jorsm/vertex-anthropic"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vertexAnthropic.refreshModels",
        "title": "Vertex Anthropic: Refresh Models"
      }
    ],
    "languageModelChatProviders": [
      {
        "identifier": "vertex-anthropic",
        "name": "Vertex Claude (Anthropic)",
        "displayName": "Vertex Claude (Anthropic)",
        "vendor": "Google Cloud Vertex AI"
      }
    ],
    "configuration": {
      "title": "Vertex Anthropic",
      "properties": {
        "vertexAnthropic.projectId": {
          "type": "string",
          "default": "",
          "description": "GCP Project ID to use with Vertex AI. Models and regions are auto-discovered."
        },
        "vertexAnthropic.modelCatalogUrl": {
          "type": "string",
          "default": "https://raw.githubusercontent.com/jorsm/vertex-anthropic/refs/heads/develop/src/models.json",
          "description": "URL to a remote models.json catalog. The extension fetches this on every discovery (with a 3 s timeout) and falls back to the bundled catalog if unavailable. Set to empty to use only the bundled catalog."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.34.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@anthropic-ai/vertex-sdk": "^0.14.4"
  }
}
