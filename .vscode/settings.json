// Place your settings in this file to overwrite default and user settings.
{
	"files.exclude": {
		"out": false // set this to true to hide the "out" folder with the compiled JS files
	},
	"search.exclude": {
		"out": true // set this to false to include "out" folder in search results
	},
	// Turn off tsc task auto detection since we have the necessary tasks as npm scripts
	"typescript.tsc.autoDetect": "off",
	"chat.tools.terminal.autoApprove": {
		"npx tsx": true
	},
	"autodoc.contextFiles": [
		"README.md",
		"package.json"
	],
	"autodoc.mappings": [
		{
			"name": "Core Architecture",
			"source": "src/{extension.ts,VertexChatModelDispatcher.ts}",
			"doc": "docs/architecture.md"
		},
		{
			"name": "Model Providers",
			"source": "src/providers/**/*.ts",
			"doc": "docs/providers.md"
		},
		{
			"name": "Usage & Billing",
			"source": "src/{UsageTrackerService.ts,CostStatusBar.ts,DashboardWebview.ts}",
			"doc": "docs/usage-and-billing.md"
		},
		{
			"name": "Features",
			"source": "src/CommitMessage.ts",
			"doc": "docs/features.md"
		}
	]
}